# Application mode: development, test, or production.
NODE_ENV=development

# Backend HTTP port.
PORT=5000

# MongoDB connection string for local MongoDB or Atlas.
MONGO_URL=mongodb://127.0.0.1:27017/restaurant_management

# Allowed frontend origins, comma-separated.
CORS_ORIGIN=http://localhost:5173

# Maximum request body size for JSON and URL-encoded payloads.
API_PAYLOAD_LIMIT=10mb
